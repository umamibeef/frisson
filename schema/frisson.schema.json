{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/frisson.schema.json",
  "title": "Frisson Document",
  "description": "Semantic schema for a parsed Frisson v0.1 draft document.",
  "type": "object",
  "required": ["frisson", "tracks", "sections", "flow"],
  "additionalProperties": false,
  "properties": {
    "frisson": {
      "const": "0.1"
    },
    "title": {
      "type": "string"
    },
    "creator": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "seed": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mix": {
          "$ref": "#/$defs/mix"
        }
      }
    },
    "tracks": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/track"
      }
    },
    "sections": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/section"
      }
    },
    "flow": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/item"
      }
    }
  },
  "$defs": {
    "track": {
      "type": "object",
      "required": ["locations"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "creator": {
          "type": "string"
        },
        "album": {
          "type": "string"
        },
        "identifier": {
          "type": "string"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "locations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "section": {
      "type": "object",
      "required": ["mode", "items"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": ["sequence", "shuffle", "choice", "weighted_choice"]
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/item"
          }
        },
        "repeat": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "object",
              "required": ["min", "max"],
              "additionalProperties": false,
              "properties": {
                "min": {
                  "type": "integer",
                  "minimum": 0
                },
                "max": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          ]
        },
        "selection": {
          "$ref": "#/$defs/selection"
        },
        "mix": {
          "$ref": "#/$defs/mix"
        },
        "transition_in": {
          "$ref": "#/$defs/transition"
        },
        "transition_out": {
          "$ref": "#/$defs/transition"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "item": {
      "type": "object",
      "oneOf": [
        {
          "required": ["track"],
          "not": {
            "required": ["section"]
          }
        },
        {
          "required": ["section"],
          "not": {
            "required": ["track"]
          }
        }
      ],
      "additionalProperties": false,
      "properties": {
        "track": {
          "type": "string"
        },
        "section": {
          "type": "string"
        },
        "weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "clip": {
          "$ref": "#/$defs/clip"
        },
        "mix": {
          "$ref": "#/$defs/mix"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "without_replacement": {
          "type": "boolean"
        }
      }
    },
    "clip": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start_ms": {
          "type": "integer",
          "minimum": 0
        },
        "end_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "mix": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gain_db": {
          "type": "number"
        },
        "crossfade_ms": {
          "type": "integer",
          "minimum": 0
        },
        "fade_in_ms": {
          "type": "integer",
          "minimum": 0
        },
        "fade_out_ms": {
          "type": "integer",
          "minimum": 0
        },
        "normalize": {
          "type": "boolean"
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["cut", "fade", "crossfade"]
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
